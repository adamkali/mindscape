        { "actionId": "navigate_right", "keys": ["ArrowRight"], "enabled": true },
        { "actionId": "navigate_first", "keys": ["Home"], "enabled": true },
        { "actionId": "navigate_last", "keys": ["End"], "enabled": true },
        { "actionId": "select_item", "keys": ["Enter", "Space"], "enabled": true },
